<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Urdu Safari - Learn Urdu Game</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Baloo+Bhaijaan+2:wght@400;500;700&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Nunito', sans-serif;
            background-color: #f0fdf4;
            background-image: radial-gradient(#bbf7d0 1px, transparent 1px);
            background-size: 20px 20px;
        }
        .urdu-text {
            font-family: 'Baloo Bhaijaan 2', cursive;
            direction: rtl;
        }
        .card-flip {
            perspective: 1000px;
        }
        .card-inner {
            transition: transform 0.6s;
            transform-style: preserve-3d;
        }
        .card-flip.flipped .card-inner {
            transform: rotateY(180deg);
        }
        .card-front, .card-back {
            backface-visibility: hidden;
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }
        .card-back {
            transform: rotateY(180deg);
        }
        .bounce-in {
            animation: bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        @keyframes bounceIn {
            0% { transform: scale(0.8); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        .pop-out {
            animation: popOut 0.3s ease-out forwards;
        }
        @keyframes popOut {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(0); opacity: 0; }
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4 text-slate-800">

    <div id="app" class="w-full max-w-lg bg-white rounded-3xl shadow-xl overflow-hidden relative min-h-[600px] flex flex-col border-4 border-green-400">
        <!-- Dynamic Content will be injected here -->
    </div>

    <script>
        // Game Data
        const vocabData = {
            numbers: {
                title: "Numbers",
                icon: "🔢",
                color: "bg-blue-500",
                lightColor: "bg-blue-100",
                items: [
                    { en: "One", ur: "ایک", rom: "Ek", emoji: "1️⃣" },
                    { en: "Two", ur: "دو", rom: "Do", emoji: "2️⃣" },
                    { en: "Three", ur: "تین", rom: "Teen", emoji: "3️⃣" },
                    { en: "Four", ur: "چار", rom: "Char", emoji: "4️⃣" },
                    { en: "Five", ur: "پانچ", rom: "Panch", emoji: "5️⃣" }
                ]
            },
            colors: {
                title: "Colors",
                icon: "🎨",
                color: "bg-pink-500",
                lightColor: "bg-pink-100",
                items: [
                    { en: "Red", ur: "لال", rom: "Lal", emoji: "🔴" },
                    { en: "Blue", ur: "نیلا", rom: "Neela", emoji: "🔵" },
                    { en: "Green", ur: "ہرا", rom: "Hara", emoji: "🟢" },
                    { en: "Black", ur: "کالا", rom: "Kala", emoji: "⚫" },
                    { en: "White", ur: "سفید", rom: "Safed", emoji: "⚪" }
                ]
            },
            animals: {
                title: "Animals",
                icon: "🦁",
                color: "bg-yellow-500",
                lightColor: "bg-yellow-100",
                items: [
                    { en: "Cat", ur: "بلی", rom: "Billi", emoji: "🐱" },
                    { en: "Dog", ur: "کتا", rom: "Kutta", emoji: "🐶" },
                    { en: "Bird", ur: "چڑیا", rom: "Chiriya", emoji: "🐦" },
                    { en: "Fish", ur: "مچھلی", rom: "Machli", emoji: "🐟" },
                    { en: "Horse", ur: "گھوڑا", rom: "Ghora", emoji: "🐴" }
                ]
            },
            fruits: {
                title: "Fruits",
                icon: "🍎",
                color: "bg-orange-500",
                lightColor: "bg-orange-100",
                items: [
                    { en: "Apple", ur: "سیب", rom: "Saib", emoji: "🍎" },
                    { en: "Banana", ur: "کیلا", rom: "Kela", emoji: "🍌" },
                    { en: "Mango", ur: "آم", rom: "Aam", emoji: "🥭" },
                    { en: "Orange", ur: "مالٹا", rom: "Malta", emoji: "🍊" },
                    { en: "Grapes", ur: "انگور", rom: "Angoor", emoji: "🍇" }
                ]
            }
        };

        // State Management
        let appState = {
            screen: 'home', // home, pre-game, learn, quiz, result
            category: null,
            currentIndex: 0,
            score: 0,
            questions: []
        };

        const appDiv = document.getElementById('app');

        // Helper: Shuffle Array
        function shuffleArray(array) {
            for (let i = array.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [array[i], array[j]] = [array[j], array[i]];
            }
            return array;
        }

        // Render Functions
        function render() {
            appDiv.innerHTML = '';
            
            if (appState.screen === 'home') renderHome();
            else if (appState.screen === 'pre-game') renderPreGame();
            else if (appState.screen === 'learn') renderLearn();
            else if (appState.screen === 'quiz') renderQuiz();
            else if (appState.screen === 'result') renderResult();
        }

        function renderHome() {
            appDiv.innerHTML = `
                <div class="bg-green-500 text-white p-6 text-center rounded-b-3xl shadow-md">
                    <h1 class="text-4xl font-extrabold tracking-wide mb-2">Urdu Safari</h1>
                    <p class="text-green-100 text-lg">Learn Urdu the fun way!</p>
                </div>
                <div class="p-6 flex-1 flex flex-col justify-center">
                    <h2 class="text-xl font-bold text-center mb-6 text-slate-700">Choose a Category</h2>
                    <div class="grid grid-cols-2 gap-4">
                        ${Object.keys(vocabData).map(key => `
                            <button onclick="selectCategory('${key}')" class="${vocabData[key].color} hover:opacity-90 transform hover:scale-105 transition-all text-white p-6 rounded-2xl shadow-lg flex flex-col items-center justify-center gap-2 group">
                                <span class="text-4xl group-hover:animate-bounce">${vocabData[key].icon}</span>
                                <span class="font-bold text-lg">${vocabData[key].title}</span>
                            </button>
                        `).join('')}
                    </div>
                </div>
            `;
        }

        function selectCategory(key) {
            appState.category = key;
            appState.screen = 'pre-game';
            render();
        }

        function renderPreGame() {
            const cat = vocabData[appState.category];
            appDiv.innerHTML = `
                <div class="p-4">
                    <button onclick="goHome()" class="text-slate-400 hover:text-slate-600 font-bold flex items-center gap-1 transition-colors">
                        ← Back
                    </button>
                </div>
                <div class="flex-1 flex flex-col items-center justify-center p-6 text-center bounce-in">
                    <div class="w-32 h-32 ${cat.color} rounded-full flex items-center justify-center text-6xl shadow-xl mb-6 border-4 border-white">
                        ${cat.icon}
                    </div>
                    <h2 class="text-3xl font-bold mb-8">${cat.title}</h2>
                    
                    <div class="w-full flex flex-col gap-4">
                        <button onclick="startLearn()" class="w-full py-4 bg-white border-2 border-indigo-500 text-indigo-600 hover:bg-indigo-50 rounded-xl font-bold text-xl shadow-sm transition-colors flex items-center justify-center gap-3">
                            📖 Learn Words
                        </button>
                        <button onclick="startQuiz()" class="w-full py-4 bg-indigo-500 hover:bg-indigo-600 text-white rounded-xl font-bold text-xl shadow-md transition-colors flex items-center justify-center gap-3">
                            🎮 Play Quiz
                        </button>
                    </div>
                </div>
            `;
        }

        function startLearn() {
            appState.currentIndex = 0;
            appState.screen = 'learn';
            render();
        }

        function renderLearn() {
            const cat = vocabData[appState.category];
            const item = cat.items[appState.currentIndex];
            const progress = ((appState.currentIndex + 1) / cat.items.length) * 100;

            appDiv.innerHTML = `
                <div class="${cat.color} text-white p-4 flex justify-between items-center relative">
                    <button onclick="goPreGame()" class="font-bold text-white/80 hover:text-white">← Back</button>
                    <span class="font-bold text-lg">${cat.title} (${appState.currentIndex + 1}/${cat.items.length})</span>
                    <div class="w-8"></div>
                    <!-- Progress bar -->
                    <div class="absolute bottom-0 left-0 h-1 bg-white/30 w-full">
                        <div class="h-full bg-white transition-all duration-300" style="width: ${progress}%"></div>
                    </div>
                </div>
                
                <div class="flex-1 flex flex-col items-center justify-center p-8 bg-slate-50">
                    <div class="card-flip w-full max-w-sm h-80 cursor-pointer mb-8" onclick="this.classList.toggle('flipped')">
                        <div class="card-inner w-full h-full relative shadow-xl rounded-3xl">
                            <!-- Front (English) -->
                            <div class="card-front bg-white rounded-3xl flex flex-col items-center justify-center border-4 border-slate-100">
                                <span class="text-7xl mb-4">${item.emoji}</span>
                                <h3 class="text-4xl font-extrabold text-slate-700">${item.en}</h3>
                                <p class="text-slate-400 mt-4 text-sm font-bold uppercase tracking-wider">Tap to translate</p>
                            </div>
                            <!-- Back (Urdu) -->
                            <div class="card-back ${cat.lightColor} rounded-3xl flex flex-col items-center justify-center border-4 border-white">
                                <h3 class="urdu-text text-7xl text-slate-800 mb-2 leading-tight py-4">${item.ur}</h3>
                                <p class="text-2xl font-bold text-slate-600 mb-4">${item.rom}</p>
                                <p class="text-slate-500 text-sm font-bold uppercase tracking-wider">Tap to flip back</p>
                            </div>
                        </div>
                    </div>

                    <div class="flex gap-4 w-full max-w-sm">
                        <button onclick="prevCard()" class="flex-1 py-3 bg-white border-2 border-slate-200 hover:bg-slate-100 rounded-xl font-bold text-slate-600 disabled:opacity-50 transition-colors" ${appState.currentIndex === 0 ? 'disabled' : ''}>Previous</button>
                        <button onclick="nextCard()" class="flex-1 py-3 bg-slate-800 hover:bg-slate-700 rounded-xl font-bold text-white transition-colors">
                            ${appState.currentIndex === cat.items.length - 1 ? 'Finish' : 'Next'}
                        </button>
                    </div>
                </div>
            `;
        }

        function nextCard() {
            const cat = vocabData[appState.category];
            if (appState.currentIndex < cat.items.length - 1) {
                appState.currentIndex++;
                render();
            } else {
                appState.screen = 'pre-game';
                render();
            }
        }

        function prevCard() {
            if (appState.currentIndex > 0) {
                appState.currentIndex--;
                render();
            }
        }

        function startQuiz() {
            const catItems = vocabData[appState.category].items;
            appState.score = 0;
            appState.currentIndex = 0;
            
            // Generate questions
            appState.questions = catItems.map(item => {
                let options = [item];
                // Get 3 random other items from same category
                let others = catItems.filter(i => i.en !== item.en);
                others = shuffleArray(others).slice(0, 3);
                options = options.concat(others);
                options = shuffleArray(options);
                
                return {
                    questionItem: item,
                    options: options
                };
            });
            
            appState.questions = shuffleArray(appState.questions);
            appState.screen = 'quiz';
            render();
        }

        function renderQuiz() {
            const cat = vocabData[appState.category];
            const q = appState.questions[appState.currentIndex];
            const progress = ((appState.currentIndex) / appState.questions.length) * 100;

            appDiv.innerHTML = `
                <div class="${cat.color} text-white p-4 flex justify-between items-center relative">
                    <button onclick="goPreGame()" class="font-bold text-white/80 hover:text-white">← Quit</button>
                    <span class="font-bold text-lg">Score: ${appState.score}</span>
                    <div class="w-12"></div>
                    <div class="absolute bottom-0 left-0 h-1 bg-white/30 w-full">
                        <div class="h-full bg-white transition-all duration-300" style="width: ${progress}%"></div>
                    </div>
                </div>

                <div class="flex-1 p-6 flex flex-col items-center bg-slate-50 bounce-in" id="quiz-container">
                    <span class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-2">Question ${appState.currentIndex + 1} of ${appState.questions.length}</span>
                    <div class="bg-white rounded-3xl p-8 shadow-sm w-full text-center border-2 border-slate-100 mb-8">
                        <p class="text-lg text-slate-500 mb-2">What is the Urdu word for</p>
                        <div class="text-6xl mb-2">${q.questionItem.emoji}</div>
                        <h2 class="text-3xl font-extrabold text-slate-800">${q.questionItem.en}?</h2>
                    </div>

                    <div class="w-full grid grid-cols-2 gap-4">
                        ${q.options.map((opt, index) => `
                            <button onclick="checkAnswer('${opt.en}', this)" class="quiz-option relative bg-white border-2 border-slate-200 hover:border-indigo-400 hover:bg-indigo-50 p-4 rounded-2xl flex flex-col items-center justify-center gap-1 transition-all">
                                <span class="urdu-text text-3xl text-slate-800 py-1">${opt.ur}</span>
                                <span class="text-sm text-slate-500 font-bold">${opt.rom}</span>
                            </button>
                        `).join('')}
                    </div>
                </div>
            `;
        }

        function checkAnswer(selectedEn, btnElement) {
            // Prevent multiple clicks
            const options = document.querySelectorAll('.quiz-option');
            options.forEach(btn => btn.disabled = true);

            const q = appState.questions[appState.currentIndex];
            const isCorrect = selectedEn === q.questionItem.en;

            if (isCorrect) {
                appState.score++;
                btnElement.classList.remove('border-slate-200', 'hover:bg-indigo-50');
                btnElement.classList.add('bg-green-500', 'border-green-600', 'text-white');
                btnElement.querySelectorAll('span').forEach(s => s.classList.replace('text-slate-800', 'text-white') || s.classList.replace('text-slate-500', 'text-green-100'));
                
                // Success particle effect
                const particle = document.createElement('div');
                particle.innerHTML = '✨';
                particle.className = 'absolute text-4xl pop-out pointer-events-none';
                particle.style.left = '50%';
                particle.style.top = '50%';
                particle.style.transform = 'translate(-50%, -50%)';
                btnElement.appendChild(particle);

            } else {
                btnElement.classList.remove('border-slate-200', 'hover:bg-indigo-50');
                btnElement.classList.add('bg-red-500', 'border-red-600');
                btnElement.querySelectorAll('span').forEach(s => s.classList.replace('text-slate-800', 'text-white') || s.classList.replace('text-slate-500', 'text-red-100'));

                // Highlight correct answer
                options.forEach(btn => {
                    // Check if this button contains the correct english word implicitly through its matching objects
                    const correctUrdu = q.questionItem.ur;
                    if(btn.innerHTML.includes(correctUrdu)) {
                        btn.classList.add('border-green-500', 'border-4');
                    }
                });
            }

            setTimeout(() => {
                if (appState.currentIndex < appState.questions.length - 1) {
                    appState.currentIndex++;
                    render();
                } else {
                    appState.screen = 'result';
                    render();
                }
            }, 1200);
        }

        function renderResult() {
            const total = appState.questions.length;
            const percentage = (appState.score / total) * 100;
            let message = "";
            let emoji = "";

            if (percentage === 100) { message = "Perfect! Shabash!"; emoji = "🌟"; }
            else if (percentage >= 60) { message = "Great Job!"; emoji = "🎉"; }
            else { message = "Keep Practicing!"; emoji = "💪"; }

            appDiv.innerHTML = `
                <div class="flex-1 flex flex-col items-center justify-center p-8 text-center bounce-in">
                    <div class="text-7xl mb-4">${emoji}</div>
                    <h2 class="text-3xl font-extrabold text-slate-800 mb-2">${message}</h2>
                    <p class="text-lg text-slate-500 mb-8">You scored</p>
                    
                    <div class="relative w-40 h-40 flex items-center justify-center bg-indigo-50 rounded-full mb-8 border-8 border-indigo-100 shadow-inner">
                        <div class="text-5xl font-black text-indigo-600">${appState.score}<span class="text-2xl text-indigo-400">/${total}</span></div>
                    </div>

                    <div class="w-full flex gap-4">
                        <button onclick="startQuiz()" class="flex-1 py-4 bg-indigo-500 hover:bg-indigo-600 text-white rounded-xl font-bold text-lg shadow-md transition-colors">
                            Play Again
                        </button>
                        <button onclick="goPreGame()" class="flex-1 py-4 bg-white border-2 border-slate-200 hover:bg-slate-50 text-slate-700 rounded-xl font-bold text-lg shadow-sm transition-colors">
                            Back to Menu
                        </button>
                    </div>
                </div>
            `;
        }

        function goHome() {
            appState.screen = 'home';
            appState.category = null;
            render();
        }

        function goPreGame() {
            appState.screen = 'pre-game';
            render();
        }

        // Initialize App
        render();

    </script>
</body>
</html>
